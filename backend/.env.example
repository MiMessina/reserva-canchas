# .env.example — Backend SaaS Gestión de Canchas
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env real (está en .gitignore).

# Django
DJANGO_SECRET_KEY=cambiar-por-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
DJANGO_LOG_LEVEL=INFO

# CORS (ADR-010) — orígenes permitidos separados por coma.
# En desarrollo: el servidor de Vite. En producción: el dominio real del complejo.
# platform.localhost:5173 = Panel de System Admin (equipo interno).
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://demo.localhost:5173,http://platform.localhost:5173

# PostgreSQL (debe coincidir con docker-compose.yml)
POSTGRES_DB=canchas_db
POSTGRES_USER=canchas_user
POSTGRES_PASSWORD=canchas_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Panel de System Admin (equipo interno — acceso local).
# Requiere agregar la entrada al archivo hosts del sistema (ver README).
PLATFORM_ADMIN_URL=http://platform.localhost:5173

# Superuser del Panel de System Admin (django.contrib.auth.User en esquema public).
# PLATFORM_ADMIN_PASSWORD es OBLIGATORIA; el entrypoint falla si no esta definida.
# Mismo criterio que DEMO_ADMIN_PASSWORD: evita caracteres como "!" sin comillas simples.
PLATFORM_ADMIN_EMAIL=admin@platform.localhost
PLATFORM_ADMIN_PASSWORD=

# Tenant demo — credenciales del admin inicial (usadas por entrypoint.sh).
# DEMO_ADMIN_PASSWORD es OBLIGATORIA; el entrypoint falla si no está definida.
# Usá una contraseña fuerte; este es solo el valor de ejemplo para el equipo de dev.
#
# ADVERTENCIA sobre caracteres especiales en contraseñas:
#   Evitá el signo "!" — en bash sin comillas activa la expansión de historial
#   y puede corromper el valor silenciosamente.
#   Para contraseñas con "!": envolvé el valor en comillas simples en el .env:
#     DEMO_ADMIN_PASSWORD='MiClave!Segura'
#   Alternativa más segura: elegí contraseñas sin "!" para evitar el problema.
DEMO_ADMIN_EMAIL=admin@demo.localhost
DEMO_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Email — configuracion del servidor SMTP
# ---------------------------------------------------------------------------
# En desarrollo, omitir DJANGO_EMAIL_BACKEND usa console (los mails aparecen en docker logs).
# Para SMTP real (Gmail): usa una App Password, no la contrasena normal de la cuenta.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-cuenta@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-de-gmail

# Direccion remitente de los emails transaccionales
DEFAULT_FROM_EMAIL=CANCHERO! <noreply@tudominio.com>

# URL base del frontend (usada para construir el link de reset de contrasena).
# En desarrollo: http://localhost:5173 (o el hostname del tenant, ej: http://demo.localhost:5173)
# En produccion: https://demo.tudominio.com
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Bot WhatsApp — modo de operación por tenant
# ---------------------------------------------------------------------------
# Este valor NO lo lee Django directamente; el modo se gestiona por tenant
# a través del campo Tenant.bot_mode (panel platform-admin o manage.py shell).
# Se documenta aquí como referencia para el equipo en entornos nuevos.
#
# Valores posibles:
#   mock        — muestra conversaciones seed [DEMO] (sin bot real conectado)
#   production  — muestra mensajes reales del bot Node.js
#
# Para cambiar el modo de un tenant en dev:
#   docker compose exec backend python manage.py shell -c \
#     "from apps.tenants.models import Tenant; t=Tenant.objects.get(schema_name='demo'); t.bot_mode='mock'; t.save()"
BOT_MODE=mock
