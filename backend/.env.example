# .env.example — Backend SaaS Gestión de Canchas
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env real (está en .gitignore).

# Django
DJANGO_SECRET_KEY=cambiar-por-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,demo.localhost
DJANGO_LOG_LEVEL=INFO

# CORS (ADR-010) — orígenes permitidos separados por coma.
# En desarrollo: el servidor de Vite. En producción: el dominio real del complejo.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL (debe coincidir con docker-compose.yml)
POSTGRES_DB=canchas_db
POSTGRES_USER=canchas_user
POSTGRES_PASSWORD=canchas_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Tenant demo — credenciales del admin inicial (usadas por entrypoint.sh).
# DEMO_ADMIN_PASSWORD es OBLIGATORIA; el entrypoint falla si no está definida.
# Usá una contraseña fuerte; este es solo el valor de ejemplo para el equipo de dev.
#
# ADVERTENCIA sobre caracteres especiales en contraseñas:
#   Evitá el signo "!" — en bash sin comillas activa la expansión de historial
#   y puede corromper el valor silenciosamente.
#   Para contraseñas con "!": envolvé el valor en comillas simples en el .env:
#     DEMO_ADMIN_PASSWORD='MiClave!Segura'
#   Alternativa más segura: elegí contraseñas sin "!" para evitar el problema.
DEMO_ADMIN_EMAIL=admin@demo.localhost
DEMO_ADMIN_PASSWORD=
