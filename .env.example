# .env.example — SaaS Gestión de Canchas
# Raiz del proyecto. Cubre TODAS las variables del entorno completo (db + backend + frontend).
#
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Reemplazar CADA placeholder (<...>) por un valor real.
#   3. NUNCA commitear el .env real (ya está en .gitignore).
#   4. En producción, usar un gestor de secretos (vault, env del servidor, etc.).
#
# IMPORTANTE: este archivo se versiona sin secretos reales; sirve de referencia
# para el equipo y para el CI/CD (ver RULES.md).

# ---------------------------------------------------------------------------
# PostgreSQL — debe coincidir entre los servicios db y backend en docker-compose.yml
# ---------------------------------------------------------------------------
POSTGRES_DB=canchas_db
POSTGRES_USER=canchas_user
POSTGRES_PASSWORD=<cambia-esta-contrasena-en-produccion>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Django — Backend
# ---------------------------------------------------------------------------
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=<clave-secreta-larga-y-aleatoria-minimo-50-caracteres>

# True para desarrollo local; False OBLIGATORIO en produccion (ver RULES.md)
DJANGO_DEBUG=True

# Hosts separados por coma. En desarrollo: localhost,127.0.0.1,demo.localhost
# En produccion: el dominio real del servidor (ej: canchaYA.com,*.canchaYA.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,demo.localhost

# Nivel de log del servidor Django (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# CORS (ADR-010) — orígenes permitidos separados por coma. Sin espacios.
# En desarrollo: el dev server de Vite. En produccion: el dominio real del complejo.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Tenant demo — credenciales del admin inicial (usadas por entrypoint.sh).
# DEMO_ADMIN_PASSWORD es OBLIGATORIA; el entrypoint falla si no está definida.
# Usá una contraseña fuerte incluso en desarrollo (nunca commitear el .env real).
#
# ADVERTENCIA sobre caracteres especiales en contraseñas:
#   Evitá el signo "!" — en bash sin comillas activa la expansión de historial
#   y puede corromper el valor silenciosamente.
#   Para contraseñas con "!": envolvé el valor en comillas simples en el .env:
#     DEMO_ADMIN_PASSWORD='MiClave!Segura'
#   Alternativa más segura: elegí contraseñas sin "!" para evitar el problema.
DEMO_ADMIN_EMAIL=admin@demo.localhost
DEMO_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Email — Gmail SMTP
# ---------------------------------------------------------------------------
# En desarrollo: DJANGO_EMAIL_BACKEND=console imprime los mails en docker logs.
# En produccion: usar App Password de Gmail (no la contrasena normal).
#   1. Activar 2FA en la cuenta Gmail.
#   2. Ir a Seguridad -> Contrasenas de aplicaciones -> Generar.
#   3. Pegar los 16 caracteres en EMAIL_HOST_PASSWORD.
#
# NUNCA poner la contrasena real de Gmail aqui. Usar siempre App Password.

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=<tu-cuenta@gmail.com>
EMAIL_HOST_PASSWORD=<app-password-16-chars>
DEFAULT_FROM_EMAIL=CanchaYA <reservas@canchaYA.com>

# ---------------------------------------------------------------------------
# Asistente IA (Gemini) — removido en Sprint 5. El chat fue reemplazado por el
# visor del bot WhatsApp. Ver T5-05 y rama feat/modificacion-bot.
# # Gemini removido en Sprint 5
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Frontend — Vite
# ---------------------------------------------------------------------------
# URL base de la API consumida por el frontend React.
# En desarrollo local con docker compose: http://localhost:8000/api
# En produccion: https://api.tudominio.com/api
VITE_API_BASE_URL=http://localhost:8000/api
