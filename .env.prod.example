# .env.prod.example — SaaS Gestión de Canchas (PRODUCCION)
#
# INSTRUCCIONES:
#   1. Copiar: cp .env.prod.example .env.prod
#   2. Reemplazar CADA <placeholder> con valores reales.
#   3. NUNCA commitear el .env.prod real (esta en .gitignore).
#   4. Mantener el archivo en el servidor con permisos 600:
#        chmod 600 .env.prod
#
# SERVER_IP: la IP publica del VPS (ej: 146.190.12.34).
# Se usa para construir los ALLOWED_HOSTS y CORS con nip.io.
# Reemplazar la cadena "<SERVER_IP>" por la IP real en cada variable.

# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
SERVER_IP=<SERVER_IP>

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=canchas_db
POSTGRES_USER=canchas_user
POSTGRES_PASSWORD=<contrasena-segura-minimo-32-chars>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Django — Seguridad
# ---------------------------------------------------------------------------
# Generar con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=<clave-secreta-larga-y-aleatoria-minimo-50-caracteres>

# OBLIGATORIO False en produccion (ver RULES.md)
DJANGO_DEBUG=False

# Hosts permitidos.
# Con nip.io la IP se embebe en el subdominio, por eso se incluye .nip.io
# Django acepta hostnames con punto inicial como wildcard de subdominio.
# Reemplazar <SERVER_IP> por la IP real.
DJANGO_ALLOWED_HOSTS=<SERVER_IP>,.nip.io,localhost

# Nivel de log en produccion: INFO (no DEBUG para no loguear queries)
DJANGO_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CORS (ADR-010) — orígenes del frontend con nip.io
# En produccion DEBUG=False, por lo que CORS_ALLOW_ALL_ORIGINS queda False.
# Listar aqui todos los origenes permitidos separados por coma.
# Reemplazar <SERVER_IP> por la IP real del servidor.
# ---------------------------------------------------------------------------
DJANGO_CORS_ALLOWED_ORIGINS=http://demo.<SERVER_IP>.nip.io,http://platform.<SERVER_IP>.nip.io,http://app.<SERVER_IP>.nip.io,http://lugano.<SERVER_IP>.nip.io

# ---------------------------------------------------------------------------
# Frontend — URL base de la API consumida por React
# Vite incrusta esta variable en el bundle durante el build (no en runtime).
# En produccion la API esta en el mismo dominio, manejada por el Nginx proxy.
# Se usa /api como path relativo para que funcione con cualquier subdominio.
# Reemplazar <SERVER_IP> por la IP real.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://demo.<SERVER_IP>.nip.io/api

# ---------------------------------------------------------------------------
# Tenant demo — credenciales del admin inicial (usadas por entrypoint.sh)
# ---------------------------------------------------------------------------
# DEMO_TENANT_DOMAIN: dominio que django-tenants registrara en la DB para el tenant demo.
# En desarrollo es "demo.localhost". En produccion debe ser el subdominio nip.io.
# Reemplazar <SERVER_IP> por la IP publica real.
DEMO_TENANT_DOMAIN=demo.<SERVER_IP>.nip.io

DEMO_ADMIN_EMAIL=admin@demo.localhost
DEMO_ADMIN_PASSWORD=<contrasena-fuerte-sin-exclamacion>

# ---------------------------------------------------------------------------
# Panel de System Admin
# ---------------------------------------------------------------------------
PLATFORM_ADMIN_EMAIL=admin@platform.localhost
PLATFORM_ADMIN_PASSWORD=<contrasena-fuerte-sin-exclamacion>

# ---------------------------------------------------------------------------
# Email — SMTP (Gmail App Password)
# En produccion usar backend SMTP real, no console.
# Para Gmail: activar 2FA → Seguridad → Contraseñas de aplicaciones → Generar.
# ---------------------------------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=<tu-cuenta@gmail.com>
EMAIL_HOST_PASSWORD=<app-password-16-chars-sin-espacios>
DEFAULT_FROM_EMAIL=CANCHERO! <reservas@canchero.com>

# URL base del frontend para links de reset de contraseña en emails.
# Reemplazar <SERVER_IP> por la IP real.
FRONTEND_URL=http://demo.<SERVER_IP>.nip.io

# ---------------------------------------------------------------------------
# Bot WhatsApp — modo por defecto para el tenant demo
# ---------------------------------------------------------------------------
BOT_MODE=mock
